# ============================================================
# Environment Configuration — 12-Factor App
# Copy to .env.local: cp .env.example .env.local
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8086
ENVIRONMENT=development    # development | staging | production
DEBUG=true                 # false in staging/production

# --- App ---
APP_NAME=AI Agent
APP_VERSION=1.0.0

# --- LLM ---
OPENAI_API_KEY=            # Empty = mock LLM
LLM_MODEL=gpt-4o-mini
MAX_TOKENS=500

# --- Security (MUST change in production) ---
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# --- Rate & Budget ---
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# --- Storage ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Security (optional) ---
IP_WHITELIST=              # Empty = allow all
